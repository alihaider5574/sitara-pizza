# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── JazzCash ────────────────────────────────────────────────────────────────
JAZZCASH_MERCHANT_ID=your-merchant-id
JAZZCASH_PASSWORD=your-merchant-password
JAZZCASH_INTEGRITY_SALT=your-integrity-salt
# Sandbox endpoint (switch to live in production)
JAZZCASH_ENDPOINT=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform/

# ─── EasyPaisa ───────────────────────────────────────────────────────────────
EASYPAISA_STORE_ID=your-store-id
EASYPAISA_HASH_KEY=your-hash-key
EASYPAISA_ACCOUNT_NUM=your-account-number
# Sandbox endpoint (switch to live in production)
EASYPAISA_ENDPOINT=https://easypaystg.easypaisa.com.pk/easypay/Index.jsf
